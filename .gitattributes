# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Java files
*.java text eol=lf

# Gradle files
*.gradle text eol=lf
*.gradle.kts text eol=lf
gradlew text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.properties text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows batch files need CRLF
*.bat text eol=crlf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.gif binary
